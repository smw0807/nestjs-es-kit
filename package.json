{
  "name": "nestjs-es-kit",
  "version": "0.3.1",
  "description": "Decorator-driven Elasticsearch index lifecycle management for NestJS — schema declaration, auto index sync, zero-downtime migration, and Korean nori preset",
  "license": "MIT",
  "author": "songminwoo <smw0807@gmail.com>",
  "homepage": "https://github.com/smw0807/nestjs-es-kit#readme",
  "bugs": {
    "url": "https://github.com/smw0807/nestjs-es-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smw0807/nestjs-es-kit.git"
  },
  "keywords": [
    "nestjs",
    "elasticsearch",
    "elastic",
    "decorator",
    "schema",
    "index-management",
    "mapping",
    "reindex",
    "migration",
    "nori",
    "korean",
    "typescript",
    "es8",
    "es9"
  ],
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./health": {
      "import": {
        "types": "./dist/health.d.ts",
        "default": "./dist/health.js"
      },
      "require": {
        "types": "./dist/health.d.cts",
        "default": "./dist/health.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.ko.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@elastic/elasticsearch": ">=8 <10",
    "@nestjs/common": ">=10 <12",
    "@nestjs/core": ">=10 <12",
    "@nestjs/terminus": ">=10",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/terminus": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@elastic/elasticsearch": "^8.18.2",
    "@eslint/js": "^9.30.1",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/terminus": "^11.1.1",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "rimraf": "^6.0.1",
    "testcontainers": "^11.5.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13"
  }
}
