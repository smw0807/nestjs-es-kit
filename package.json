{
  "name": "nestjs-es-kit",
  "version": "0.0.0",
  "description": "Elasticsearch index lifecycle management toolkit for NestJS",
  "license": "MIT",
  "author": "songminwoo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smw0807/nestjs-es-kit.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@elastic/elasticsearch": ">=8 <10",
    "@nestjs/common": ">=10 <12",
    "@nestjs/core": ">=10 <12",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@elastic/elasticsearch": "^8.18.2",
    "@eslint/js": "^9.30.1",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "rimraf": "^6.0.1",
    "testcontainers": "^11.5.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.13"
  }
}
